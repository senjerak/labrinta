---
import StoryLayout from "../../layouts/StoryLayout.astro";
import "../../styles/novel.css";
---

<StoryLayout>
  <script is:inline>
    preloadImages("/s_one/", [
      "roomone_dark2.gif",
      "roomone_dark4.gif",
      "CASCA_sit3.gif",
      "CASCA_sit5.gif",
      "CASCA_sit9.gif",
      "CASCA_sit6.gif",
    ]);

    waitForNovel(function prepareNovel() {
      novel.imagePath = "/s_one/"; // path to your image directory
      novel.audioPath = ""; // path to your audio directory

      /**
       * Characters
       */
      const n = new Character("");
      const casca = new Character("Casca", { color: "rgb(230, 145, 185)" });
      /**
       * Scene Nineteen - Room One Dark P4
       *
       */
      script = [
        label,
        "start",
        scene,
        "roomone_dark2.gif",

        casca,
        { image: `CASCA_sit3.gif?A=${Date.now()}`, position: cascaroom2 },

        casca,
        ". . . ZzzZZZzZzz . .",

        casca,
        ". . . . . . ZzZzz . .",

        casca,
        { image: `CASCA_sit5.gif?A=${Date.now()}`, position: cascaroom2 },

        casca,
        ". . . . huh?",

        casca,
        { image: `CASCA_sit9.gif?A=${Date.now()}`, position: cascaroom2 },

        n,
        "It never failed to surprise Casca. .",

        casca,
        { image: `CASCA_sit6.gif?A=${Date.now()}`, position: cascaroom2 },

        n,
        ". . how quickly everything changes.",

        casca,
        "Casper?",

        casca,
        { image: `CASCA_sit9.gif?A=${Date.now()}`, position: cascaroom2 },

        jsCall,
        {
          fcn: () => {
            preloadImages("/s_one/", ["roomone_dark1.gif", "CASCA_sit9.gif"]);
          },
        },

        casca,
        "Casper! Where are you?",

        jsCall,
        { fcn: changeScene(20) },
      ];
    });
  </script>
</StoryLayout>

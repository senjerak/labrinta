---
import StoryLayout from "../../layouts/StoryLayout.astro";
import "../../styles/novel.css";
---

<StoryLayout>
    <script is:inline>
        preloadImages("/s_one/", [
            "room3door.gif",
            "CASCA_fall.gif",
            "CASCA_fall2.gif",
            "outside1.gif",
            "CASCAWalkmad_L.gif",
            "CASCA_talkmadL.gif",
            "CASCA_talksadL.gif",
        ]);

        waitForNovel(function prepareNovel() {
            novel.imagePath = "/s_one/"; // path to your image directory
            novel.audioPath = ""; // path to your audio directory

            /**
             * Characters
             */
            const n = new Character("");
            const casca = new Character("Casca", {
                color: "rgb(230, 145, 185)",
            });

            /**
             * Scene Twenty - Room One Dark P5
             *
             */
            script = [
                label,
                "start",
                scene,
                "outside1.gif",

                casca,
                {
                    image: `CASCAWalkmad_L.gif?A=${Date.now()}`,
                    position: leftSidetwo,
                },

                n,
                "Somewhere Familiar.",

                casca,
                {
                    image: `outside1_casca.gif?A=${Date.now()}`,
                    position: rightSide,
                },
                casca,
                "What!? How is this possible?",

                casca,
                "Where am I?",

                casca,
                "Theres.... Theres no way to find casper here.",

                casca,
                {
                    image: `CASCA_talksadL.gif?A=${Date.now()}`,
                    position: cascalobby3,
                },

                casca,
                "This is hopeless",

                casca,
                ". . . CASPER!!!!",

                casca,
                "... I...",

                casca,
                "...I can't do this without you.",

                jsCall,
                {
                    fcn: () => {
                        preloadImages("/s_one/", [
                            "outside3.gif",
                            "CASCA_fall.gif",
                        ]);
                    },
                },

                jsCall,
                { fcn: changeScene(29) },
            ];
        });
    </script>
</StoryLayout>

---
import StoryLayout from "../../layouts/StoryLayout.astro";
import "../../styles/novel.css";
---

<StoryLayout>
  <script is:inline>
    preloadImages("/s_one/", ["overpass5.gif"]);

    waitForNovel(function prepareNovel() {
      novel.imagePath = "/s_one/"; // path to your image directory
      novel.audioPath = ""; // path to your audio directory

      /**
       * Characters
       */
      const n = new Character("");
      /**
       * Positions
       */
      /**
       * Scene Eight - Overpass 5
       *
       */
      script = [
        label,
        "start",

        scene,
        "overpass5.gif",

        n,
        "At least that made sense.",

        jsCall,
        {
          fcn: () => {
            debugger;
            const dialog = document.getElementById("dialogDiv");
            dialog.style.display = "none";
            const bg = document.getElementById("background0");
            bg.style.display = "none";
            const video = document.querySelector("#video");
            video.src = "/s_one/road.mp4";
            video.style.opacity = 1;
            video.style.display = "block";

            document.body.style.pointerEvents = "none";

            video.play();
            video.addEventListener("ended", () => {
              bg.style.display = "unset";
              dialog.style.display = "block";
              document.body.style.pointerEvents = "unset";
              video.style.display = "none";
              video.style.opacity = 0;
              playNovel();
            });
          },
        },

        pause,
        undefined,

        jsCall,
        // TODO: change to the next scene
        { fcn: changeScene(1) },
      ];
    });
  </script>
</StoryLayout>

---
import StoryLayout from "../../layouts/StoryLayout.astro";
import "../../styles/novel.css";
---

<StoryLayout>
    <script is:inline>
        preloadImages("/s_one/", [
            "room3door.gif",
            "CASCA_fall.gif",
            "CASCA_fall2.gif",
        ]);

        waitForNovel(function prepareNovel() {
            novel.imagePath = "/s_one/"; // path to your image directory
            novel.audioPath = ""; // path to your audio directory

            /**
             * Characters
             */
            const n = new Character("");
            const casca = new Character("Casca", {
                color: "rgb(230, 145, 185)",
            });

            /**
             * Positions
             */
            const cascaroom2 = new Position(45, 160, 0, 0);
            /**
             * Scene Twenty - Room One Dark P5
             *
             */
            script = [
                label,
                "start",
                scene,
                "outside3.gif",

                casca,
                {
                    image: `CASCA_fall.gif?A=${Date.now()}`,
                    position: cascamarket1,
                },

                casca,
                "I'm a terrible parent.",

                casca,
                "If I just knew what to do I wouldn't be here.",

                casca,
                "How am I supposed to... How do I...",

                casca,
                "I miss Casper...",

                casca,
                "I never meant for this to happen.. I just needed a break... I...",

                casca,
                "...oh..!!!",

                n,
                "Casca wept, surrounded by the world around them.",

                n,
                "How can you learn to love in a world that hates you?",

                n,
                "Where... is casper?",

                jsCall,
                { fcn: changeScene(32) },
            ];
        });
    </script>
</StoryLayout>

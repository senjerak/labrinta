---
import StoryLayout from "../../layouts/StoryLayout.astro";
import "../../styles/novel.css";
---

<StoryLayout>
  <script is:inline>
    preloadImages("/s_one/", ["transport.gif", "CASCA_portal.gif"]);

    waitForNovel(function prepareNovel() {
      novel.imagePath = "/s_one/"; // path to your image directory
      novel.audioPath = ""; // path to your audio directory

      /**
       * Characters
       */
      const casca = new Character("Casca", { color: "rgb(230, 145, 185)" });

      /**
       * Scene Twenty Two - Portal
       *
       */
      script = [
        label,
        "start",
        scene,
        "transport.gif",

        jsCall,
        {
          fcn: () => {
            preloadImages("/s_one/", ["market.gif", "CASCA_fall.gif"]);
          },
        },

        casca,
        { image: `CASCA_portal.gif?A=${Date.now()}`, position: cascaportal },

        casca,
        "A-AAAA!!!",

        jsCall,
        { fcn: changeScene(23) },
      ];
    });
  </script>
</StoryLayout>

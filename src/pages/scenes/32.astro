---
import StoryLayout from "../../layouts/StoryLayout.astro";
import "../../styles/novel.css";
---

<StoryLayout>
    <script is:inline>
        preloadImages("/s_one/", [
            "room3door.gif",
            "CASCA_fall.gif",
            "CASCA_fall2.gif",
        ]);

        waitForNovel(function prepareNovel() {
            novel.imagePath = "/s_one/"; // path to your image directory
            novel.audioPath = ""; // path to your audio directory

            /**
             * Characters
             */
            const n = new Character("");
            const casca = new Character("Casca", {
                color: "rgb(230, 145, 185)",
            });

            const casper = new Character("Casper", {
                color: "rgba(218, 234, 127, 1)",
            });

            /**
             * Positions
             */
            const cascaroom2 = new Position(45, 160, 0, 0);
            /**
             * Scene Twenty - Room One Dark P5
             *
             */
            script = [
                label,
                "start",
                scene,
                "outside1.gif",

                casca,
                {
                    image: `CASCA_talkmadL.gif?A=${Date.now()}`,
                    position: cascalobby3,
                },

                casca,
                "woah!!",

                casca,
                "...These rocks look like signals...",

                casca,
                "But.. how...",

                n,
                "The moment casca placed their hand on the stone, a signal burst outwards in all directions.",

                casca,
                "C A S P E R !",

                casca,
                "...",

                n,
                "...",

                casper,
                "C A S C A !",

                casca,
                "!!!",

                jsCall,
                { fcn: changeScene(30) },
            ];
        });
    </script>
</StoryLayout>

---
import StoryLayout from "../../layouts/StoryLayout.astro";
import "../../styles/novel.css";
---

<StoryLayout>
  <script is:inline>
    preloadImages("/s_one/", ["overpass.gif"]);

    waitForNovel(function prepareNovel() {
      novel.imagePath = "/s_one/"; // path to your image directory
      novel.audioPath = ""; // path to your audio directory

      /**
       * Characters
       */
      const n = new Character("");
      const casper = new Character("Casper", {
        color: "rgba(218, 234, 127, 1)",
      });
      const casca = new Character("Casca", { color: "rgb(230, 145, 185)" });

      /**
       * Scene Four - Overpass
       *
       */
      script = [
        label,
        "start",

        scene,
        "overpass.gif",

        n,
        "Well... the road seemed like it was pretty clear. You would think with all the highways that were built that there would be less traffic",
        n,
        "Everyone seems to have somewhere to be, all at the same time, every day.",

        jsCall,
        {
          fcn: () => {
            preloadImages("/s_one/", [
              "overpass3.gif",
              "casperride1.gif",
              "cascaride1.gif",
            ]);
          },
        },

        casper,
        " . . oh no!",

        jsCall,
        { fcn: changeScene(5) },
      ];
    });
  </script>
</StoryLayout>

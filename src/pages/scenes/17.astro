---
import StoryLayout from "../../layouts/StoryLayout.astro";
import "../../styles/novel.css";
---

<StoryLayout>
  <script is:inline>
    preloadImages("/s_one/", [
      "roomone_dark2.gif",
      "CASCA_sit3.gif",
      "caspersadbasic.gif",
    ]);

    waitForNovel(function prepareNovel() {
      novel.imagePath = "/s_one/"; // path to your image directory
      novel.audioPath = ""; // path to your audio directory

      /**
       * Characters
       */
      const n = new Character("");
      const casper = new Character("Casper", {
        color: "rgba(218, 234, 127, 1)",
      });
      const casca = new Character("Casca", { color: "rgb(230, 145, 185)" });

      /**
       * Scene Seventeen - Room One Dark P2
       *
       */
      script = [
        label,
        "start",
        scene,
        "roomone_dark2.gif",

        casca,
        { image: `CASCA_sit3.gif?A=${Date.now()}`, position: cascaroom2 },

        casper,
        { image: "caspersadbasic.gif", position: casperlobby4 },

        casper,
        "whats going on?",

        casca,
        ". . .",

        casper,
        "who's there?",

        n,
        ". . .",

        casper,
        "i'm scared. . !",

        jsCall,
        {
          fcn: () => {
            preloadImages("/s_one/", [
              "roomone_dark2.gif",
              "CASPER_talk.gif",
              "CASCA_sit3.gif",
            ]);
          },
        },

        casca,
        ". . ZZzZzzz. . .",

        jsCall,
        { fcn: changeScene(18) },
      ];
    });
  </script>
</StoryLayout>

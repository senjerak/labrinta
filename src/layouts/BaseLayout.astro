---
import { ClientRouter } from "astro:transitions";
import Loader from "../components/Loader.astro";

interface Props {
    title?: string;
}

const { title = 'LA BRINTA' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/media/labrifavi.png" />
    <ClientRouter />
    <div slot="fallback"><Loader /></div>
    <slot name="head" />
</head>
<body>
    <slot />
</body>
</html>

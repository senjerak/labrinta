---
interface Props {
    text?: string;
}

const { text = '' } = Astro.props;
---

<div class="headerdivider"></div>
<div class="footer">
    {text ? (
        <a href="/">
            <marquee>{text}</marquee>
        </a>
    ) : (
        <marquee></marquee>
    )}
    <div class="headerdividerfoot"></div>
</div>
